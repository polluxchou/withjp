# Supabase — get these from your project settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase service role key (server-only, never expose to client)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Anthropic API key — https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI API key — https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Gemini API key — https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIza...

# Optional: route Gemini requests through a relay/proxy when Google APIs
# are blocked from the server environment.
# GEMINI_BASE_URL=https://your-proxy-endpoint.com
